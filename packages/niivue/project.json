{
  "name": "niivue",
  "projectType": "library",
  "tags": ["type:lib", "lang:typescript"],
  "targets": {
    "build": {
      "command": "bun run codegen:assets && bunx --bun vite build --config vite.config.lib.ts",
      "options": { "cwd": "{projectRoot}" },
      "inputs": [
        "typescript",
        "{projectRoot}/vite.config.lib.ts",
        "{projectRoot}/vite.config.js",
        "{projectRoot}/src/**/*",
        "{projectRoot}/public/**/*",
        "{projectRoot}/scripts/**/*"
      ],
      "outputs": ["{projectRoot}/dist"]
    },
    "dev": {
      "command": "bun run codegen:assets && bunx --bun vite --open /examples/index.html",
      "options": { "cwd": "{projectRoot}" }
    },
    "typecheck": {
      "command": "bunx tsc --noEmit",
      "options": { "cwd": "{projectRoot}" },
      "inputs": ["typescript"]
    },
    "lint": {
      "command": "bunx biome check {projectRoot}",
      "inputs": ["typescript"]
    },
    "format": {
      "command": "bunx biome format {projectRoot} --write",
      "inputs": ["typescript"]
    },
    "test": {
      "command": "bun test",
      "options": { "cwd": "{projectRoot}" },
      "inputs": ["typescript"]
    }
  }
}
