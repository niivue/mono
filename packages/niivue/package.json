{
  "name": "@niivue/niivue",
  "version": "1.0.0-rc.10",
  "type": "module",
  "description": "WebGPU/WebGL2 browser-based medical image visualization",
  "main": "./dist/niivue.js",
  "module": "./dist/niivue.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/niivue.js"
    },
    "./webgpu": {
      "types": "./dist/index.webgpu.d.ts",
      "import": "./dist/niivue.webgpu.js"
    },
    "./webgl2": {
      "types": "./dist/index.webgl2.d.ts",
      "import": "./dist/niivue.webgl2.js"
    },
    "./viewport": {
      "types": "./dist/control/NVCanvasViewportController.d.ts",
      "import": "./dist/viewport.js"
    },
    "./assets/fonts": {
      "types": "./dist/assets/fonts/index.d.ts",
      "import": "./dist/assets/fonts/index.js"
    },
    "./assets/matcaps": {
      "types": "./dist/assets/matcaps/index.d.ts",
      "import": "./dist/assets/matcaps/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE.fsleyes-plugin-mrs",
    "PORTING.md"
  ],
  "sideEffects": false,
  "scripts": {
    "codegen:assets": "node scripts/generate-assets.js",
    "gen-fixtures": "bun scripts/generate-range-poc-fixture.ts && bun scripts/generate-tile-range-poc-fixture.ts",
    "ensure-samples": "bun scripts/ensure-samples.ts",
    "dev": "bun run codegen:assets && bun run gen-fixtures && bun run ensure-samples && bunx --bun vite --port 5273 --strictPort --open /examples/index.html",
    "dev:perf": "bun run codegen:assets && bunx --bun vite --port 5273 --strictPort --open /examples/benchmark.html",
    "build": "bun run codegen:assets && bunx --bun vite build --config vite.config.lib.ts",
    "build:examples": "bun run codegen:assets && bun run gen-fixtures && bunx --bun vite build --config vite.config.examples.ts",
    "deploy": "bun run codegen:assets && bun run gen-fixtures && bunx --bun vite build --config vite.config.examples.ts --mode production",
    "demo": "bun run build:examples && bunx http-server dist/ --cors -o",
    "preview": "vite preview",
    "e2e:serve": "bun run codegen:assets && bunx --bun vite --port 5273 --strictPort",
    "test:e2e": "playwright test",
    "convert:legacy": "bun run scripts/convert-legacy-nvd.ts",
    "lint": "bunx biome check src",
    "lint:fix": "bunx biome check src --fix",
    "typecheck": "tsc --noEmit",
    "size:entries": "node scripts/report-entry-sizes.js",
    "size:check": "node scripts/check-entry-sizes.js",
    "bench": "bun run bench/run-bench.ts",
    "bench:compare": "bash bench/compare-to-main.sh",
    "bench:report": "bash bench/report.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/niivue/niivue.git"
  },
  "keywords": [
    "neuroimaging",
    "nifti",
    "webgpu",
    "webgl",
    "medical-imaging",
    "brain",
    "mri",
    "visualization"
  ],
  "author": "niivue authors",
  "license": "BSD-2-Clause",
  "bugs": {
    "url": "https://github.com/niivue/niivue/issues"
  },
  "homepage": "https://github.com/niivue/niivue",
  "dependencies": {
    "cbor-x": "^1.6.0",
    "clipper2-ts": "^2.0.1-13",
    "earcut": "^3.0.2",
    "gl-matrix": "^3.4.4",
    "nifti-reader-js": "^0.8.0"
  },
  "devDependencies": {
    "@cornerstonejs/codec-openjpeg": "^1.3.0",
    "@niivue/dev-images": "workspace:*",
    "@playwright/test": "1.59.1",
    "@types/bun": "^1.3.12",
    "@types/earcut": "^3.0.0",
    "@webgpu/types": "^0.1.69",
    "dicom-parser": "^1.8.21",
    "geotiff": "^3.0.5",
    "http-server": "^14.1.1",
    "playwright": "^1.59.1",
    "typescript": "^5.6.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "zarrita": "^0.7.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
