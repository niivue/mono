{
  "name": "@niivue/nv-ext-brain2print",
  "version": "1.0.0-rc.0",
  "type": "module",
  "description": "Tinygrad-generated WebGPU brain segmentation models for NiiVue (subcortical and tissue_fast)",
  "main": "./dist/nv-ext-brain2print.js",
  "module": "./dist/nv-ext-brain2print.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/nv-ext-brain2print.js"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@itk-wasm/cuberille": "^0.2.0",
    "@itk-wasm/mesh-filters": "^1.7.0",
    "@niivue/niivue": "workspace:*",
    "@niivue/nv-ext-image-processing": "workspace:*",
    "@niivue/nv-ext-niimath": "workspace:*"
  },
  "dependencies": {
    "cbor-x": "^1.6.0"
  },
  "devDependencies": {
    "@itk-wasm/cuberille": "^0.2.0",
    "@itk-wasm/mesh-filters": "^1.7.0",
    "@niivue/niivue": "workspace:*",
    "@niivue/nv-ext-image-processing": "workspace:*",
    "@niivue/nv-ext-niimath": "workspace:*",
    "@webgpu/types": "^0.1.52",
    "typescript": "~5.8.3",
    "vite": "^6.3.2",
    "vite-plugin-dts": "^4.5.4"
  },
  "scripts": {
    "build": "bunx --bun vite build",
    "typecheck": "bunx tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  }
}
