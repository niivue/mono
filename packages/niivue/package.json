{
  "name": "@niivue/niivue",
  "version": "1.0.0-rc.4",
  "type": "module",
  "description": "WebGPU/WebGL2 browser-based medical image visualization",
  "main": "./dist/niivuegpu.js",
  "module": "./dist/niivuegpu.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/niivuegpu.js"
    },
    "./webgpu": {
      "types": "./dist/index.webgpu.d.ts",
      "import": "./dist/niivuegpu.webgpu.js"
    },
    "./webgl2": {
      "types": "./dist/index.webgl2.d.ts",
      "import": "./dist/niivuegpu.webgl2.js"
    },
    "./assets/fonts": {
      "types": "./dist/assets/fonts/index.d.ts",
      "import": "./dist/assets/fonts/index.js"
    },
    "./assets/matcaps": {
      "types": "./dist/assets/matcaps/index.d.ts",
      "import": "./dist/assets/matcaps/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "codegen:assets": "node scripts/generate-assets.js",
    "dev": "bun run codegen:assets && bunx --bun vite --port 5273 --strictPort --open /examples/index.html",
    "dev:perf": "NIIVUE_PERF=1 bun run codegen:assets && NIIVUE_PERF=1 bunx --bun vite --port 5273 --strictPort --open /examples/benchmark.html",
    "build": "bun run codegen:assets && bunx --bun vite build --config vite.config.lib.ts",
    "build:perf": "NIIVUE_PERF=1 bun run codegen:assets && NIIVUE_PERF=1 bunx --bun vite build --config vite.config.lib.ts",
    "build:examples": "bun run codegen:assets && bunx --bun vite build --config vite.config.examples.ts",
    "build:examples:perf": "NIIVUE_PERF=1 bun run codegen:assets && NIIVUE_PERF=1 bunx --bun vite build --config vite.config.examples.ts",
    "deploy": "bun run codegen:assets && bunx --bun vite build --config vite.config.examples.ts --mode production",
    "demo": "bun run build:examples && bunx http-server dist/ --cors -o",
    "preview": "vite preview",
    "lint": "bunx biome check src",
    "lint:fix": "bunx biome check src --fix",
    "typecheck": "tsc --noEmit",
    "size:entries": "node scripts/report-entry-sizes.js",
    "size:check": "node scripts/check-entry-sizes.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/niivue/niivue.git"
  },
  "keywords": [
    "neuroimaging",
    "nifti",
    "webgpu",
    "webgl",
    "medical-imaging",
    "brain",
    "mri",
    "visualization"
  ],
  "author": "niivue authors",
  "license": "BSD-2-Clause",
  "bugs": {
    "url": "https://github.com/niivue/niivue/issues"
  },
  "homepage": "https://github.com/niivue/niivue",
  "dependencies": {
    "cbor-x": "^1.6.0",
    "clipper2-ts": "^2.0.1-13",
    "earcut": "^3.0.2",
    "gl-matrix": "^3.4.4",
    "nifti-reader-js": "^0.8.0"
  },
  "devDependencies": {
    "@niivue/dev-images": "workspace:*",
    "@types/bun": "^1.3.12",
    "@types/earcut": "^3.0.0",
    "@webgpu/types": "^0.1.69",
    "http-server": "^14.1.1",
    "typescript": "^5.6.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
