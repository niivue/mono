{
  "name": "@niivue/nv-web-component",
  "version": "1.0.0-rc.1",
  "private": false,
  "type": "module",
  "description": "Web component bindings for NiiVue",
  "main": "./dist/nv-web-component.js",
  "module": "./dist/nv-web-component.js",
  "types": "./dist/niivue-web-component.d.ts",
  "exports": {
    ".": {
      "types": "./dist/niivue-web-component.d.ts",
      "import": "./dist/nv-web-component.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "bunx --bun vite build",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test"
  },
  "peerDependencies": {
    "@niivue/niivue": "workspace:*"
  },
  "devDependencies": {
    "@niivue/niivue": "workspace:*",
    "@types/bun": "^1.3.12",
    "typescript": "^5.9.3",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "lit": "^3.3.2"
  }
}
