{
  "name": "ipyniivue",
  "projectType": "library",
  "tags": ["type:lib", "lang:python"],
  "targets": {
    "codegen": {
      "command": "bun run scripts/codegen.ts",
      "options": { "cwd": "{projectRoot}" },
      "dependsOn": [
        { "projects": ["niivue"], "target": "build" },
        { "projects": ["nv-ext-image-processing"], "target": "build" },
        { "projects": ["nv-ext-drawing"], "target": "build" }
      ],
      "inputs": [
        "{projectRoot}/scripts/**/*",
        "{workspaceRoot}/packages/niivue/src/NVControlBase.ts",
        "{workspaceRoot}/packages/niivue/src/NVEvents.ts",
        "{workspaceRoot}/packages/niivue/src/NVTypes.ts",
        "{workspaceRoot}/packages/niivue/src/NVConstants.ts",
        "{workspaceRoot}/packages/niivue/dist/**/*",
        "{workspaceRoot}/packages/nv-ext-image-processing/dist/**/*",
        "{workspaceRoot}/packages/nv-ext-drawing/dist/**/*"
      ],
      "outputs": [
        "{projectRoot}/api.generated.json",
        "{projectRoot}/src/ipyniivue/_generated.py",
        "{projectRoot}/src/ipyniivue/static/widget.js",
        "{projectRoot}/src/ipyniivue/static/_widget.template.js"
      ]
    },
    "build": {
      "command": "bun scripts/pixi-or-skip.ts python -m build --wheel --sdist --outdir dist .",
      "options": { "cwd": "{projectRoot}" },
      "dependsOn": ["codegen"],
      "inputs": [
        "{projectRoot}/pyproject.toml",
        "{projectRoot}/src/**/*",
        "{projectRoot}/README.md"
      ],
      "outputs": ["{projectRoot}/dist"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "commands": [
          "bunx biome check scripts",
          "bun scripts/pixi-or-skip.ts ruff check src scripts examples",
          "bun scripts/pixi-or-skip.ts ruff format --check src"
        ],
        "parallel": false
      },
      "inputs": [
        "python",
        "{projectRoot}/scripts/**/*",
        "{projectRoot}/pyproject.toml",
        "{workspaceRoot}/biome.json"
      ]
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "commands": [
          "bunx biome format --write scripts",
          "bun scripts/pixi-or-skip.ts ruff format src scripts examples",
          "bun scripts/pixi-or-skip.ts ruff check --fix src scripts examples"
        ],
        "parallel": false
      },
      "inputs": [
        "python",
        "{projectRoot}/scripts/**/*",
        "{projectRoot}/pyproject.toml",
        "{workspaceRoot}/biome.json"
      ]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "commands": ["bunx tsc --noEmit", "bun scripts/pixi-or-skip.ts mypy"],
        "parallel": false
      },
      "inputs": [
        "python",
        "{projectRoot}/scripts/**/*",
        "{projectRoot}/tsconfig.json",
        "{projectRoot}/pyproject.toml"
      ]
    },
    "test": {
      "command": "bun scripts/pixi-or-skip.ts pytest",
      "options": { "cwd": "{projectRoot}" },
      "inputs": ["python", "{projectRoot}/pyproject.toml"]
    },
    "smoke": {
      "command": "bun scripts/pixi-or-skip.ts smoke",
      "options": { "cwd": "{projectRoot}" },
      "dependsOn": ["codegen"],
      "inputs": [
        "{projectRoot}/examples/**/*.ipynb",
        "{projectRoot}/src/**/*",
        "{projectRoot}/pyproject.toml"
      ]
    },
    "nx-release-publish": {
      "executor": "nx:noop",
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
