# ipyniivue: bundled widget JS (~1.3 MB) is auto-generated by codegen.
# Run `bunx nx codegen ipyniivue` to (re)build it. Smaller reviewable
# codegen outputs (`_widget.template.js`, `_generated.py`,
# `api.generated.json`) stay committed as a code-review surface.
packages/ipyniivue/src/ipyniivue/static/widget.js

