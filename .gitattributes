# Medical image volumes
packages/dev-images/images/**/*.nii.gz filter=lfs diff=lfs merge=lfs -text
packages/dev-images/images/**/*.mgz filter=lfs diff=lfs merge=lfs -text
packages/dev-images/images/**/*.BRIK.gz filter=lfs diff=lfs merge=lfs -text
packages/dev-images/images/**/*.HEAD filter=lfs diff=lfs merge=lfs -text

# Meshes & tractography
packages/dev-images/images/**/*.mz3 filter=lfs diff=lfs merge=lfs -text
packages/dev-images/images/**/*.trx filter=lfs diff=lfs merge=lfs -text
packages/dev-images/images/**/*.trk filter=lfs diff=lfs merge=lfs -text
packages/dev-images/images/**/*.tck filter=lfs diff=lfs merge=lfs -text
packages/dev-images/images/**/*.vtk filter=lfs diff=lfs merge=lfs -text
packages/dev-images/images/**/*.pial filter=lfs diff=lfs merge=lfs -text
packages/dev-images/images/**/*.curv filter=lfs diff=lfs merge=lfs -text
packages/dev-images/images/**/*.jcon filter=lfs diff=lfs merge=lfs -text
packages/dev-images/images/**/*.tsf filter=lfs diff=lfs merge=lfs -text
packages/dev-images/images/**/*.tt.gz filter=lfs diff=lfs merge=lfs -text

# Other binary assets
packages/dev-images/images/**/*.png filter=lfs diff=lfs merge=lfs -text

# medgfx app bundled sample volumes
apps/medgfx/medgfx/**/*.nii.gz filter=lfs diff=lfs merge=lfs -text

# ipyniivue example notebooks reference small NIfTI fixtures used to
# construct demos (e.g. array-backed volumes). Track them via LFS so
# future additions do not bloat the regular git history.
packages/ipyniivue/examples/**/*.nii.gz filter=lfs diff=lfs merge=lfs -text
packages/ipyniivue/examples/**/*.mz3 filter=lfs diff=lfs merge=lfs -text
packages/ipyniivue/examples/**/*.trx filter=lfs diff=lfs merge=lfs -text
packages/ipyniivue/examples/**/*.trk filter=lfs diff=lfs merge=lfs -text
