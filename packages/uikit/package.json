{
  "name": "@niivue/uikit",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "description": "UIKit: controls and widgets integrated into the NiiVue rendering lifecycle",
  "main": "./dist/uikit.js",
  "module": "./dist/uikit.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/uikit.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bunx --bun vite build",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test"
  },
  "peerDependencies": {
    "@niivue/niivue": "workspace:*"
  },
  "devDependencies": {
    "@niivue/niivue": "workspace:*",
    "@types/bun": "^1.3.12",
    "typescript": "^5.9.3",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^4.5.4"
  }
}
