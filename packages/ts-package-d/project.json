{
  "name": "ts-package-d",
  "projectType": "library",
  "tags": ["type:lib", "lang:typescript"],
  "targets": {
    "build": {
      "command": "bun build index.ts --outdir dist",
      "options": { "cwd": "{projectRoot}" },
      "inputs": ["typescript"],
      "outputs": ["{projectRoot}/dist"]
    },
    "typecheck": {
      "command": "bunx tsc --noEmit",
      "options": { "cwd": "{projectRoot}" },
      "inputs": ["typescript"]
    },
    "lint": {
      "command": "bunx biome check {projectRoot}",
      "inputs": ["typescript"]
    },
    "format": {
      "command": "bunx biome format {projectRoot} --write",
      "inputs": ["typescript"]
    },
    "test": {
      "command": "bun test",
      "options": { "cwd": "{projectRoot}" },
      "inputs": ["typescript"]
    }
  }
}
